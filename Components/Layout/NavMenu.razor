@using Microsoft.AspNetCore.Components.Authorization

<MudNavMenu>
    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="/dashboard" Icon="@Icons.Material.Filled.Dashboard" Style="color: #FFFFFF;">
                Dashboard
            </MudNavLink>

            @if (context.User.IsInRole("Admin"))
            {
                <MudNavLink Href="/students" Icon="@Icons.Material.Filled.People" Style="color: #FFFFFF;">
                    Students
                </MudNavLink>
                <MudNavLink Href="/courses" Icon="@Icons.Material.Filled.MenuBook" Style="color: #FFFFFF;">
                    Courses
                </MudNavLink>
                <MudNavLink Href="/enrollments" Icon="@Icons.Material.Filled.AppRegistration" Style="color: #FFFFFF;">
                    Enrollments
                </MudNavLink>
                <MudNavLink Href="/grades" Icon="@Icons.Material.Filled.Grade" Style="color: #FFFFFF;">
                    Grades
                </MudNavLink>
                <MudNavLink Href="/users" Icon="@Icons.Material.Filled.ManageAccounts" Style="color: #FFFFFF;">
                    Users
                </MudNavLink>
            }
            else if (context.User.IsInRole("Instructor"))
            {
                <MudNavLink Href="/students" Icon="@Icons.Material.Filled.People" Style="color: #FFFFFF;">
                    Students
                </MudNavLink>
                <MudNavLink Href="/courses" Icon="@Icons.Material.Filled.MenuBook" Style="color: #FFFFFF;">
                    Courses
                </MudNavLink>
                <MudNavLink Href="/enrollments" Icon="@Icons.Material.Filled.AppRegistration" Style="color: #FFFFFF;">
                    Enrollments
                </MudNavLink>
                <MudNavLink Href="/grades" Icon="@Icons.Material.Filled.Grade" Style="color: #FFFFFF;">
                    Grades
                </MudNavLink>
            }
            else if (context.User.IsInRole("Student"))
            {
                <MudNavLink Href="/courses" Icon="@Icons.Material.Filled.MenuBook" Style="color: #FFFFFF;">
                    Courses
                </MudNavLink>
                <MudNavLink Href="/enrollment-chart-table" Icon="@Icons.Material.Filled.TableChart" Style="color: #FFFFFF;">
                    Enrollment Chart Table
                </MudNavLink>
                <MudNavLink Href="/my-grades" Icon="@Icons.Material.Filled.Grade" Style="color: #FFFFFF;">
                    My Grade
                </MudNavLink>
            }

            <MudNavLink Href="/logout" Icon="@Icons.Material.Filled.Logout" Style="color: #FF9800;">
                Logout
            </MudNavLink>
        </Authorized>
        <NotAuthorized />
    </AuthorizeView>
</MudNavMenu>
