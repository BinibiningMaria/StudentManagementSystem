@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div style="background: #F8F9FA; min-height: 100vh;">
    @Body
</div>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1A237E",
            Secondary = "#E3F2FD",
            Background = "#F8F9FA",
            Surface = "#FFFFFF",
            TextPrimary = "#1A237E",
            TextSecondary = "#546E7A",
        }
    };
}
